    "check:package": "publint && pnpm pack --pack-destination /tmp && attw /tmp/aleph-front-bkp-ds-*.tgz --profile esm-only --exclude-entrypoints ./styles/tokens.css && rm -f /tmp/aleph-front-bkp-ds-*.tgz",
    "lint": "oxlint --import-plugin src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
